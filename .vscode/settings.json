{
  "dart.warnWhenEditingFilesOutsideWorkspace": false,
  "dart.enableSdkFormatter": true,
  "dart.lineLength": 100,
  "dart.enableSnippets": true,
  "dart.previewFlutterUiGuides": true,
  "[dart]": {
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit"
    },
    "editor.rulers": [80, 100],
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "flutter.deviceManager.commonlyUsedDevices": ["chrome", "android"],
  "flutter.runMode": "debug",
  "flutter.showWebServerDeviceForProfile": true,
  "flutter.showEmulator": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/build": false,
    "**/.dart_tool": true,
    "**/.flutter-plugins": true,
    "**/.flutter-plugins-dependencies": true,
    "**/.packages": true,
    "**/*.iml": true,
    "**/.idea": true
  },
  "search.exclude": {
    "**/.dart_tool": true,
    "**/.packages": true,
    "**/build": true,
    "**/.idea": true,
    "**/.vscode": true,
    "**/.git": true,
    "node_modules": true,
    "**/.gradle": true
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "files.autoSave": "onFocusChange",
  "editor.acceptSuggestionOnEnter": "on",
  "editor.suggest.preview": true,
  "editor.inlineSuggest.enabled": true,
  "json.schemas": [],
  "json.validate.enable": true,
  "extensions.ignoreRecommendations": false,
  "files.watcherExclude": {
    "**/.dart_tool/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/build/**": true
  },
  "Todo Tree.tree.showBadges": true,
  "Todo Tree.tree.showCountBadges": true,
  "Todo Tree.filtering.includeGlobs": ["**/*.dart"],
  "dart.openDevTools": "flutter",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true
}
