# EditorConfig for Silent Space
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

# Dart files
[*.dart]
indent_style = space
indent_size = 2
max_line_length = 100

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files (pubspec, config)
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Lock files
[*.lock]
insert_final_newline = false

# Gradle/build files
[*.{gradle,gradle.kts}]
indent_style = space
indent_size = 4

# Swift (iOS)
[*.swift]
indent_style = space
indent_size = 4

# Kotlin (Android)
[*.kt]
indent_style = space
indent_size = 4

# XML (Android resources)
[*.xml]
indent_style = space
indent_size = 4

# Properties files
[*.properties]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# CMake/C++ (Linux/macOS)
[{CMakeLists.txt,*.cc,*.h}]
indent_style = space
indent_size = 2
